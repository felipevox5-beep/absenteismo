# =====================================================
# BANCO DE DADOS PostgreSQL
# =====================================================
DB_HOST=postgres.seu-servidor.com
DB_PORT=5432
DB_NAME=controleabsenteismo
DB_USER=controleabsenteismo_user
DB_PASSWORD=sua_senha_super_segura_aqui
DB_POOL_MAX=20
DB_POOL_MIN=2

# =====================================================
# SERVIDOR
# =====================================================
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# =====================================================
# API GEMINI (Google AI)
# =====================================================
GEMINI_API_KEY=sua_chave_gemini_aqui

# =====================================================
# AUTENTICAÇÃO E SEGURANÇA
# =====================================================
JWT_SECRET=sua_chave_jwt_super_segura_aqui_minimo_32_caracteres
SESSION_SECRET=sua_chave_session_super_segura_aqui
CORS_ORIGIN=https://seu-dominio.com.br

# =====================================================
# ARMAZENAMENTO DE ARQUIVOS (Atestados)
# =====================================================
STORAGE_TYPE=local
UPLOAD_DIR=/app/uploads/atestados
MAX_FILE_SIZE=5242880

# =====================================================
# CONFIGURAÇÕES DE EMAIL (Notificações)
# =====================================================
MAIL_HOST=smtp.seu-provider.com
MAIL_PORT=587
MAIL_USER=seu_email@empresa.com
MAIL_PASSWORD=sua_senha_email
MAIL_FROM=noreply@empresa.com
MAIL_FROM_NAME=Sistema de Absenteísmo

# =====================================================
# LOGS E MONITORAMENTO
# =====================================================
LOG_LEVEL=info
LOG_FILE=/app/logs/app.log
ENABLE_REQUEST_LOGGING=true

# =====================================================
# CONFIGURAÇÕES DE APLICAÇÃO
# =====================================================
MAX_ABSENCES_PER_MONTH=3
ALERT_THRESHOLD_CID_RECURRENCE=2
REQUIRE_MEDICAL_CERTIFICATE=true
SYSTEM_TIMEZONE=America/Sao_Paulo

# =====================================================
# VITE/FRONTEND
# =====================================================
VITE_API_URL=https://seu-dominio.com.br/api
VITE_APP_NAME=Controle de Absenteísmo
